# 忽略打包和临时目录
dist/
tmp/
outputs/
backup/

# 忽略临时文件与生成的 Dashboard HTML
*.tmp
*_Dashboard.html

# 忽略开发设计文档与打包脚本
idea.md
package.sh
RELEASE_NOTE.md

# 忽略本地 DuckDB 数据库文件（避免上传敏感数据）
*.db
*.db-shm
*.db-wal
*.duckdb

# 忽略本地敏感配置文件
config.txt
echart_config.txt

# 忽略打包生成的 skill 产物
*.skill

# 忽略 macOS 系统文件
.DS_Store

# 忽略 Python 缓存文件
__pycache__/
*.py[cod]
*$py.class
.coverage
logs/
.claude/
.planning/
.pytest_cache/
.ruff_cache/
test/
examples/all_356/*.html
